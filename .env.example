
#---- Database ----
POSTGRES_USER=reviewmind
POSTGRES_PASSWORD=reviewmind_dev
POSTGRES_DB=reviewmind
DATABASE_URL=postgresql://reviewmind:reviewmind_dev@postgres:5432/reviewmind

#---- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- AI Provider (Gemini) ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
# Local dev: path to the .pem file
GITHUB_PRIVATE_KEY_PATH=
# Railway / production: base64-encoded PEM contents (no file needed)
GITHUB_PRIVATE_KEY=

# --- App Config ---
ENVIRONMENT=development
LOG_LEVEL=info
